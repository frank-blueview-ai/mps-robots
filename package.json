{
  "name": "mps-robots",
  "version": "1.0.0",
  "description": "This project serves a local ORA arm control page through project-local NGINX.",
  "main": "Ora-move.js",
  "scripts": {
    "build:frontend": "vite build",
    "dev:frontend": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:local": "playwright test tests/local-controller.spec.js",
    "test:ora": "playwright test tests/official-editor-connection.spec.js",
    "test:bridge": "playwright test tests/bridge-readonly.spec.js",
    "bridge": "node scripts/ora-bridge-server.js",
    "server:go": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-go-server.ps1 start",
    "server:go:stop": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-go-server.ps1 stop",
    "server:go:status": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-go-server.ps1 status"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0"
  }
}
